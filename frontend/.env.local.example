# Base URL of the FastAPI backend.
# Local dev: the backend runs on port 8000 (see backend README).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Production (Vercel): point at your deployed backend, e.g.
# NEXT_PUBLIC_API_BASE=https://et-dashboard-api.onrender.com

# Field Health module tab. Off => the tab is hidden and the app is identical to
# the irrigation-only build. Keep in sync with the backend FEATURE_FIELD_HEALTH.
NEXT_PUBLIC_FEATURE_FIELD_HEALTH=true
