# ---- Google Sheet source ---------------------------------------------------
# Defaults to the build's target sheet (shared "Anyone with link → Viewer").
# Set SHEET_ID=demo to run the bundled sample season instead (no network needed).
SHEET_ID=1USpOtSe83zCZdXUz19MnhOvIxZDpZI-8ak20AIEX320
# Optional: override the per-tab CSV template (must contain "{sheet}").
# SHEET_CSV_BASE=https://docs.google.com/spreadsheets/d/<ID>/gviz/tq?tqx=out:csv&sheet={sheet}

# ---- Forecast location -----------------------------------------------------
# Latitude is read from the sheet (engine input). Longitude is NOT in the sheet,
# so set it here for the Open-Meteo forecast. Without it, the forecast falls back
# to 3-day persistence. (Colby, KS ≈ -101.05.)
LON=-101.05
# LAT=            # force a forecast latitude independent of the sheet (rare)

# ---- Forecast / decision knobs --------------------------------------------
# Forecast tail length: long enough to reach provisional stage dates and project
# the trigger forward. Open-Meteo gives ~16 real days; the rest is persistence.
FORECAST_HORIZON_DAYS=21
RECENT_ETC_WINDOW=5
STALE_AFTER_DAYS=2

# ---- Caching & CORS --------------------------------------------------------
CACHE_TTL_SECONDS=600
FRONTEND_ORIGIN=http://localhost:3000
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast

# ---- Field Health module (isolated feature) --------------------------------
# Master switch. Off => the /api/field router is never mounted and the app is
# identical to the irrigation-only build.
FEATURE_FIELD_HEALTH=true
# Copernicus Data Space Ecosystem (CDSE) Sentinel Hub OAuth client (v1, required
# for live imagery). Create at https://dataspace.copernicus.eu (free).
SH_CLIENT_ID=
SH_CLIENT_SECRET=
# v2 (not used in v1, set ahead of time if you like):
OPENET_API_KEY=
ANTHROPIC_API_KEY=
